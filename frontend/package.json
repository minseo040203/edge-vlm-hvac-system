{
  "name": "edge-vlm-hvac-frontend",
  "version": "1.0.0",
  "description": "Frontend dashboard for Edge VLM HVAC system",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
